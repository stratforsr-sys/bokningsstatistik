# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/telink_meetings"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Session
SESSION_SECRET="your-session-secret-change-this"

# Microsoft Azure AD (för Graph API OAuth)
AZURE_CLIENT_ID="your-azure-client-id"
AZURE_TENANT_ID="your-azure-tenant-id"
AZURE_CLIENT_SECRET="your-azure-client-secret"
AZURE_REDIRECT_URI="http://localhost:3000/auth/callback"

# Frontend URL (för invite-länkar)
FRONTEND_URL="http://localhost:3000"

# SÄKERHET - VIKTIGT!
# - Byt JWT_SECRET och SESSION_SECRET i production!
# - Använd starka, slumpmässiga värden (minst 32 tecken)
# - Dela ALDRIG dessa värden publicly (lägg till .env i .gitignore)
